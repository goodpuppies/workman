from "./dto.wm" import {
  TokenDto, LexRoundTripDto, StructuralItemDto, RecoveryMarkDto,
  VirtualArtifactDto, MapPieceDto, StructuralParseDto,
  lexRoundTrip as lexRoundTripInternal,
  parseStructural as parseStructuralInternal
};
from "./semantic_dto.wm" import {
  SemanticDeclDto, SemanticProjectionDto,
  projectSemantic as projectSemanticInternal
};

-- The entry module owns the stable JavaScript ABI. Internal WM representations
-- stay behind this wrapper even while the package evolves.
let lexRoundTrip = (source: String) => {
  lexRoundTripInternal(source)
};

let parseStructural = (source: String) => {
  parseStructuralInternal(source)
};

let projectSemantic = (source: String) => {
  projectSemanticInternal(source)
};
