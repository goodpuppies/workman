{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "wm-mini",
  "scopeName": "source.wm-mini",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#bindings" },
    { "include": "#json" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#functions" },
    { "include": "#fields" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.wm-mini",
          "match": "--.*$"
        },
        {
          "name": "comment.line.double-slash.wm-mini",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.wm-mini",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.wm-mini",
              "match": "\\\\(?:[nt\"\\\\])"
            },
            {
              "name": "invalid.illegal.escape.wm-mini",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.other.backtick.wm-mini",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.wm-mini",
              "match": "\\\\(?:[nt`\\\\])"
            },
            {
              "name": "invalid.illegal.escape.wm-mini",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "begin": "\\b(from)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.from.wm-mini" }
          },
          "end": "(?=;)|$",
          "name": "meta.import.wm-mini",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            {
              "name": "keyword.control.import.wm-mini",
              "match": "\\b(import|as)\\b"
            },
            {
              "name": "storage.modifier.import.wm-mini",
              "match": "\\b(type|unsafe)\\b"
            },
            {
              "name": "support.module.js-target.wm-mini",
              "match": "\\bjs\\.(?:global|module)\\b"
            },
            {
              "name": "variable.other.import.member.wm-mini",
              "match": "\\b[a-zA-Z_][A-Za-z0-9_]*\\b"
            },
            { "include": "#types" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "begin": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "beginCaptures": {
            "1": { "name": "storage.type.type.wm-mini" },
            "2": { "name": "entity.name.type.alias.wm-mini" }
          },
          "end": "(?=;)|$",
          "name": "meta.type.declaration.wm-mini",
          "patterns": [
            { "include": "#typeparameters" },
            {
              "match": "(=)|(\\|)",
              "captures": {
                "1": { "name": "keyword.operator.assignment.wm-mini" },
                "2": { "name": "keyword.operator.type.constructor.wm-mini" }
              }
            },
            { "include": "#types" },
            { "include": "#comments" },
            { "include": "#punctuation" }
          ]
        },
        {
          "begin": "\\b(record)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "beginCaptures": {
            "1": { "name": "storage.type.type.wm-mini" },
            "2": { "name": "entity.name.type.wm-mini" }
          },
          "end": "(?=;)|$",
          "name": "meta.record.declaration.wm-mini",
          "patterns": [
            { "include": "#typeparameters" },
            { "include": "#types" },
            { "include": "#comments" },
            { "include": "#operators" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "match": "\\b(let)\\s+(?:(rec)\\s+)?(?:([a-z_][A-Za-z0-9_]*)|([A-Z][A-Za-z0-9_]*)|(_))\\b",
          "captures": {
            "1": { "name": "storage.type.wm-mini" },
            "2": { "name": "storage.modifier.recursive.wm-mini" },
            "3": { "name": "entity.name.function.wm-mini" },
            "4": { "name": "entity.name.type.constructor.wm-mini" },
            "5": { "name": "variable.language.wildcard.wm-mini" }
          }
        },
        {
          "name": "storage.modifier.binding.wm-mini",
          "match": "\\band\\b"
        }
      ]
    },
    "json": {
      "patterns": [
        {
          "name": "support.type.json.wm-mini",
          "match": "\\bJSON\\b(?=\\s*[\\{\\[])"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.wm-mini",
          "match": "\\b(if|else|match)\\b"
        },
        {
          "name": "storage.type.wm-mini",
          "match": "\\b(let|type|record)\\b"
        },
        {
          "name": "storage.modifier.wm-mini",
          "match": "\\b(rec|and|unsafe)\\b"
        },
        {
          "name": "keyword.control.import.wm-mini",
          "match": "\\b(from|import|as)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.panic.wm-mini",
          "match": "\\bPanic\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.pattern-var.wm-mini",
          "match": "\\bVar\\b(?=\\s*\\()"
        },
        {
          "name": "support.type.json.wm-mini",
          "match": "\\bJSON\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.wm-mini",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.constructor.wm-mini",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "name": "variable.object.property.wm-mini",
          "match": "(?<=\\.)\\b[a-zA-Z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.wm-mini",
          "match": "\\b(Int|String|Bool|Void|Float)\\b"
        },
        {
          "name": "support.type.js.wm-mini",
          "match": "\\bJs\\.[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.wm-mini",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.wm-mini",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.void.wm-mini",
          "match": "\\bvoid\\b"
        },
        {
          "name": "constant.numeric.float.wm-mini",
          "match": "(?<![A-Za-z0-9_])-?\\b[0-9]+\\.[0-9]+\\b(?![A-Za-z0-9_])"
        },
        {
          "name": "constant.numeric.integer.wm-mini",
          "match": "(?<![A-Za-z0-9_])-?\\b[0-9]+\\b(?![A-Za-z0-9_])"
        },
        {
          "name": "variable.language.wildcard.wm-mini",
          "match": "\\b_\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.wm-mini",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipe.wm-mini",
          "match": ":>"
        },
        {
          "name": "keyword.operator.spread.wm-mini",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.comparison.wm-mini",
          "match": "<=|>=|==|!="
        },
        {
          "name": "keyword.operator.logical.wm-mini",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.wm-mini",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.wm-mini",
          "match": "\\+\\+|\\+|-|[*/]|%"
        },
        {
          "name": "keyword.operator.comparison.wm-mini",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.misc.wm-mini",
          "match": "!|:|\\|"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.wm-mini",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.wm-mini",
          "match": ","
        },
        {
          "name": "punctuation.definition.block.wm-mini",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.group.wm-mini",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.list.wm-mini",
          "match": "[\\[\\]]"
        }
      ]
    },
    "typeparameters": {
      "patterns": [
        {
          "begin": "<",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.begin.wm-mini" }
          },
          "end": ">",
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.wm-mini" }
          },
          "name": "meta.type.parameters.wm-mini",
          "patterns": [
            { "include": "#types" },
            { "include": "#comments" },
            { "include": "#punctuation" }
          ]
        }
      ]
    }
  }
}
