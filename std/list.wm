let rec map = match(items, f) => {
  ([], _) => { [] },
  ([head, ..rest], f) => { [f(head), ..map(rest, f)] }
};

let rec foldRight = match(items, initial, f) => {
  ([], initial, _) => { initial },
  ([head, ..rest], initial, f) => {
    f(head, foldRight(rest, initial, f))
  }
};

let collectWith = (empty, combine, items) => {
  foldRight(items, empty, combine)
};
