{
  "name": "@goodpuppies/workman",
  "version": "0.1.16",
  "license": "MIT",
  "exports": {
    ".": "./src/cli.ts"
  },
  "tasks": {
    "generate-assets": "deno run --allow-read --allow-write scripts/generate_assets.ts",
    "check": "deno check src/main.ts src/lsp/server.ts tests/*.ts",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net=github.com,release-assets.githubusercontent.com tests",
    "publish": "deno task generate-assets && deno task publish:vscode",
    "publish:vscode": "npm --prefix editors/vscode ci --include=dev && npm --prefix editors/vscode run package",
    "install": "deno run --allow-read --allow-write --allow-env scripts/install.ts",
    "compile": "deno run -A src/main.ts",
    "frontend-v2:build": "deno run -A src/main.ts compile-library tooling/frontend-v2/frontend.wm tooling/frontend-v2/frontend-v2.generated.mjs",
    "wmslang:builtins": "deno run -A scripts/generate_wmslang_builtin_catalog.ts",
    "wmslang:builtins:check": "deno run -A scripts/generate_wmslang_builtin_catalog.ts --check",
    "wmslang:build": "deno run -A src/main.ts compile-library tooling/wmslang/compiler.wm tooling/wmslang/wmslang.generated.mjs",
    "profile:webhook": "deno run -A scripts/profile_typecheck.ts examples/webhook.wm",
    "profile:webhook:cpu": "deno run -A --cpu-prof --cpu-prof-flamegraph --cpu-prof-md --cpu-prof-dir=profiles --cpu-prof-name=webhook-typecheck.cpuprofile scripts/profile_typecheck.ts examples/webhook.wm",
    "profile:frontend-v2": "deno run -A scripts/profile_frontend_v2.ts structural 1",
    "profile:frontend-v2:cpu": "deno run -A --cpu-prof --cpu-prof-flamegraph --cpu-prof-md --cpu-prof-dir=profiles --cpu-prof-name=frontend-v2.cpuprofile scripts/profile_frontend_v2.ts raw-structural 1",
    "wm": "deno run -A src/main.ts"
  },
  "imports": {
    "@webgpu/types": "npm:@webgpu/types@0.1.64",
    "@std/assert": "jsr:@std/assert@^1.0.17",
    "peggy": "npm:peggy@^5.0.6",
    "typescript": "npm:typescript@^7.0.2",
    "typescript-api": "npm:@typescript/typescript6@^6.0.2"
  },
  "fmt": {
    "lineWidth": 100
  }
}
